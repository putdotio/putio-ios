// Checked-in defaults for open-source-safe local builds.
// Override these in Config/Local.xcconfig for developer machines or via xcodebuild
// build settings in CI and fastlane.

PUTIO_APP_IDENTIFIER = com.putio.opensource.ios
PUTIO_DEVELOPMENT_TEAM =

PUTIO_OAUTH_CLIENT_ID = 3001
PUTIO_CHROMECAST_RECEIVER_APP_ID = CC1AD845
PUTIO_INTERCOM_API_KEY =
PUTIO_INTERCOM_APP_ID =
PUTIO_SENTRY_DSN =

PRODUCT_BUNDLE_IDENTIFIER = $(PUTIO_APP_IDENTIFIER)
DEVELOPMENT_TEAM = $(PUTIO_DEVELOPMENT_TEAM)
