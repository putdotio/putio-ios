require "shellwords"

update_fastlane

default_platform(:ios)

def xcode_build_settings_from_env(keys)
  keys.filter_map do |key|
    value = ENV[key].to_s
    next if value.empty?

    %(#{key}=#{Shellwords.escape(value)})
  end.join(" ")
end

platform :ios do
  lane :beta do |options|
    setup_ci

    app_store_connect_api_key(
      issuer_id: ENV["APPSTORE_CONNECT_ISSUER_ID"],
      key_id: ENV["APPSTORE_CONNECT_KEY_ID"],
      key_filepath: ENV["APPSTORE_CONNECT_KEY_FILEPATH"]
    )

    unless ENV["MATCH_GIT_URL"].to_s.empty?
      match(type: ENV.fetch("MATCH_TYPE", "appstore"), platform: "ios")
    end

    if options[:bump_type]
      increment_version_number_in_xcodeproj(
        bump_type: options[:bump_type],
        scheme: "Putio"
      )
    end

    increment_build_number

    build_app(
      workspace: "Putio.xcworkspace",
      scheme: "Putio",
      xcargs: xcode_build_settings_from_env(%w[
        PUTIO_APP_IDENTIFIER
        PUTIO_DEVELOPMENT_TEAM
        PUTIO_OAUTH_CLIENT_ID
        PUTIO_CHROMECAST_RECEIVER_APP_ID
        PUTIO_INTERCOM_API_KEY
        PUTIO_INTERCOM_APP_ID
        PUTIO_SENTRY_DSN
      ])
    )

    pilot(
      distribute_external: true,
      groups: ["Beta"],
      changelog: "Please visit put.io/beta for details."
    )
  end
end
