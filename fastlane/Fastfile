require "shellwords"

update_fastlane

default_platform(:ios)

def first_present(*values)
  values.find { |value| !value.to_s.empty? }
end

def fastlane_bool(value, default:)
  return default if value.to_s.empty?

  %w[1 true yes on].include?(value.to_s.downcase)
end

def normalized_version(value)
  candidate = value.to_s.strip
  return nil if candidate.empty?

  candidate.sub(/\Av/, "")
end

def generated_build_number
  Time.now.utc.strftime("%y.%m.%d.%H.%M")
end

def resolved_build_number(*values)
  first_present(*values, generated_build_number)
end

def setup_putio_ci_keychain
  return unless is_ci

  run_suffix = [ENV["GITHUB_RUN_ID"], ENV["GITHUB_RUN_ATTEMPT"]]
    .reject { |value| value.to_s.empty? }
    .join("-")
  default_keychain_name = run_suffix.empty? ? "putio-ios-ci.keychain" : "putio-ios-ci-#{run_suffix}.keychain"
  default_keychain_password = run_suffix.empty? ? "putio-ios-ci" : "putio-ios-ci-#{run_suffix}"

  keychain_name = first_present(ENV["PUTIO_CI_KEYCHAIN_NAME"], default_keychain_name)
  keychain_password = first_present(ENV["PUTIO_CI_KEYCHAIN_PASSWORD"], default_keychain_password)

  create_keychain(
    name: keychain_name,
    password: keychain_password,
    default_keychain: true,
    unlock: true,
    timeout: 3600,
    lock_when_sleeps: true,
    lock_after_timeout: false,
    add_to_search_list: true,
    require_create: true
  )

  ENV["MATCH_KEYCHAIN_NAME"] = keychain_name
  ENV["MATCH_KEYCHAIN_PASSWORD"] = keychain_password
end

def with_temporary_file_state(paths)
  snapshots = paths.to_h do |path|
    [path, File.binread(path)]
  end

  yield
ensure
  snapshots.each do |path, contents|
    File.binwrite(path, contents)
  end
end

def xcode_build_settings_from_values(values)
  values.filter_map do |key, raw_value|
    value = raw_value.to_s
    next if value.empty?

    %(#{key}=#{Shellwords.escape(value)})
  end.join(" ")
end

def xcode_build_settings_from_env(keys, extras: {})
  values = keys.to_h do |key|
    [key, ENV[key]]
  end

  xcode_build_settings_from_values(values.merge(extras))
end

platform :ios do
  lane :beta do |options|
    setup_putio_ci_keychain

    beta_build_number = resolved_build_number(options[:build_number], ENV["PUTIO_BETA_BUILD_NUMBER"])
    beta_changelog = first_present(options[:changelog], ENV["PUTIO_BETA_CHANGELOG"])
    beta_groups = first_present(options[:groups], ENV["PUTIO_BETA_GROUPS"]).to_s.split(",").map(&:strip).reject(&:empty?)
    distribute_external = fastlane_bool(
      first_present(options[:distribute_external], ENV["PUTIO_BETA_DISTRIBUTE_EXTERNAL"]),
      default: true
    )

    app_store_connect_api_key(
      issuer_id: ENV["APPSTORE_CONNECT_ISSUER_ID"],
      key_id: ENV["APPSTORE_CONNECT_KEY_ID"],
      key_filepath: ENV["APPSTORE_CONNECT_KEY_FILEPATH"]
    )

    unless ENV["MATCH_GIT_URL"].to_s.empty?
      match(type: ENV.fetch("MATCH_TYPE", "appstore"), platform: "ios", readonly: is_ci)
    end

    with_temporary_file_state(%w[
      Putio.xcodeproj/project.pbxproj
      Putio/Info.plist
    ]) do
      increment_build_number(build_number: beta_build_number)

      build_app(
        workspace: "Putio.xcworkspace",
        scheme: "Putio",
        xcargs: xcode_build_settings_from_env(%w[
          PUTIO_APP_IDENTIFIER
          PUTIO_DEVELOPMENT_TEAM
          PUTIO_OAUTH_CLIENT_ID
          PUTIO_CHROMECAST_RECEIVER_APP_ID
          PUTIO_INTERCOM_API_KEY
          PUTIO_INTERCOM_APP_ID
          PUTIO_SENTRY_DSN
        ])
      )

      pilot(
        distribute_external: distribute_external,
        groups: beta_groups.empty? ? ["Beta"] : beta_groups,
        changelog: beta_changelog.to_s.empty? ? "Please visit put.io/beta for details." : beta_changelog,
        skip_waiting_for_build_processing: true
      )
    end
  end

  lane :release do |options|
    setup_putio_ci_keychain

    release_version = normalized_version(first_present(options[:version], ENV["PUTIO_RELEASE_VERSION"]))
    release_build_number = resolved_build_number(options[:build_number], ENV["PUTIO_RELEASE_BUILD_NUMBER"])
    release_changelog = first_present(options[:changelog], ENV["PUTIO_RELEASE_CHANGELOG"])
    release_groups = first_present(options[:groups], ENV["PUTIO_RELEASE_GROUPS"]).to_s.split(",").map(&:strip).reject(&:empty?)
    distribute_external = fastlane_bool(
      first_present(options[:distribute_external], ENV["PUTIO_RELEASE_DISTRIBUTE_EXTERNAL"]),
      default: false
    )

    app_store_connect_api_key(
      issuer_id: ENV["APPSTORE_CONNECT_ISSUER_ID"],
      key_id: ENV["APPSTORE_CONNECT_KEY_ID"],
      key_filepath: ENV["APPSTORE_CONNECT_KEY_FILEPATH"]
    )

    unless ENV["MATCH_GIT_URL"].to_s.empty?
      match(type: ENV.fetch("MATCH_TYPE", "appstore"), platform: "ios", readonly: is_ci)
    end

    with_temporary_file_state(%w[
      Putio.xcodeproj/project.pbxproj
      Putio/Info.plist
    ]) do
      if release_version
        increment_version_number_in_xcodeproj(
          version_number: release_version,
          scheme: "Putio"
        )
      end

      increment_build_number(build_number: release_build_number)

      build_app(
        workspace: "Putio.xcworkspace",
        scheme: "Putio",
        xcargs: xcode_build_settings_from_env(%w[
          PUTIO_APP_IDENTIFIER
          PUTIO_DEVELOPMENT_TEAM
          PUTIO_OAUTH_CLIENT_ID
          PUTIO_CHROMECAST_RECEIVER_APP_ID
          PUTIO_INTERCOM_API_KEY
          PUTIO_INTERCOM_APP_ID
          PUTIO_SENTRY_DSN
        ])
      )

      pilot(
        distribute_external: distribute_external,
        groups: release_groups,
        changelog: release_changelog.to_s.empty? ? "See the GitHub release notes for details." : release_changelog,
        skip_waiting_for_build_processing: true
      )
    end
  end
end
